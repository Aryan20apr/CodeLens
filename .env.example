# =============================================================================
# Application (Convict-validated — see src/config/)
# Copy this file to `.env` and fill in real values. Never commit `.env`.
# =============================================================================

NODE_ENV=development
PORT=3000
LOG_LEVEL=info
# Set to false in production for JSON logs (Docker/log aggregators)
LOG_PRETTY=true

# =============================================================================
# Redis configuration (app connection — Convict-validated under redis.*)
# =============================================================================

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
REDIS_QUEUE_DB=1

# Auth (REQUIRED for secured Redis). Generate with: openssl rand -base64 48 | tr -d '\n'
REDIS_PASSWORD=

# Image / container
# Pinned to Redis 7.x: avoids rare SIGSEGV with Redis 8 bundled modules + threading on Docker Desktop ARM.
REDIS_IMAGE_TAG=7-alpine
REDIS_CONTAINER_NAME=codelens-redis

# Networking
# Host interface to bind the published port to.
# - dev:  127.0.0.1 (loopback only, safe default)
# - prod: 127.0.0.1 (front with reverse proxy / private network)
REDIS_BIND_HOST=127.0.0.1
REDIS_PORT=6379

# Redis Insight GUI (docker compose — dev override publishes the port)
REDIS_INSIGHT_IMAGE_TAG=2.70
REDIS_INSIGHT_CONTAINER_NAME=codelens-redis-insight
REDIS_INSIGHT_BIND_HOST=127.0.0.1
REDIS_INSIGHT_PORT=5540

# Persistence / data
REDIS_DATA_PATH=./.data/redis

# Memory & eviction (tune per workload)
REDIS_MAXMEMORY=512mb
REDIS_MAXMEMORY_POLICY=allkeys-lru

# Resource limits (prod)
REDIS_CPU_LIMIT=1.0
REDIS_MEM_LIMIT=768m
REDIS_CPU_RESERVATION=0.25
REDIS_MEM_RESERVATION=256m

# =============================================================================
# GitHub App (PR review bot — separate from GITHUB_CLIENT_ID user OAuth)
# =============================================================================

GITHUB_APP_ID=
GITHUB_WEBHOOK_SECRET=
# e.g. https://github.com/apps/your-app-slug/installations/new
GITHUB_APP_INSTALL_URL=http://github.com/apps/codelens-ai-review/installations/new

# PEM: inline, base64, or path (see src/config/github-app-key.util.ts)
# GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
# GITHUB_APP_PRIVATE_KEY_BASE64=
GITHUB_APP_PRIVATE_KEY_PATH=

# =============================================================================
# Database (Prisma)
# =============================================================================

DATABASE_URL=postgresql://user:password@localhost:5432/codelens

# =============================================================================
# Auth / LLM (required for full app — see existing convict schema)
# =============================================================================

JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
ENCRYPTION_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=
GEMINI_MODEL=

LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=<your-api-key>
LANGSMITH_PROJECT=codelens-dev
