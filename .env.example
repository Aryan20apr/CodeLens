# =============================================================================
# Application (Convict-validated — see src/config/)
# Copy this file to `.env` and fill in real values. Never commit `.env`.
# =============================================================================

NODE_ENV=development
PORT=3000
LOG_LEVEL=info
# Set to false in production for JSON logs (Docker/log aggregators)
LOG_PRETTY=true

# =============================================================================
# Redis configuration (app connection — Convict-validated under redis.*)
# =============================================================================

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0

# Auth (REQUIRED for secured Redis). Generate with: openssl rand -base64 48 | tr -d '\n'
REDIS_PASSWORD=

# Image / container
# Pinned to Redis 7.x: avoids rare SIGSEGV with Redis 8 bundled modules + threading on Docker Desktop ARM.
REDIS_IMAGE_TAG=7-alpine
REDIS_CONTAINER_NAME=codelens-redis

# Networking
# Host interface to bind the published port to.
# - dev:  127.0.0.1 (loopback only, safe default)
# - prod: 127.0.0.1 (front with reverse proxy / private network)
REDIS_BIND_HOST=127.0.0.1
REDIS_PORT=6379

# Persistence / data
REDIS_DATA_PATH=./.data/redis

# Memory & eviction (tune per workload)
REDIS_MAXMEMORY=512mb
REDIS_MAXMEMORY_POLICY=allkeys-lru

# Resource limits (prod)
REDIS_CPU_LIMIT=1.0
REDIS_MEM_LIMIT=768m
REDIS_CPU_RESERVATION=0.25
REDIS_MEM_RESERVATION=256m
