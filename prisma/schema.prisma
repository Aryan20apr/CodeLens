// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}


// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum Role {
  USER
  ADMIN
}

enum OAuthProvider {
  GITHUB
  GOOGLE
}
// ---------------------------------------------------------------------------
// User
// ---------------------------------------------------------------------------

model User {
  id        String   @id @default(uuid(7))
  email     String   @unique
  name      String?
  avatarUrl String?

  // Email/password login — null for pure-OAuth users
  hashedPassword String?

  // API key: SHA-256 hex of raw key only (indexed unique lookup). Raw key is
  // returned once at registration / regeneration and is never persisted.
  apiKeyHash String @unique

  role Role @default(USER)

  oauthAccounts OAuthAccount[]

  
  evaluations   Evaluation[]
  presets       Preset[]
  developerMemory DeveloperMemory?

  refreshTokens RefreshToken[]

  preferences UserPreferences?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
}
// ---------------------------------------------------------------------------
// OAuth accounts linked to a user
// ---------------------------------------------------------------------------
model OAuthAccount {
  id           String        @id @default(uuid(7))
  provider     OAuthProvider
  providerUid  String       

  
  accessToken  String?
  
  refreshToken String?
  tokenExpiry  DateTime?

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([provider, providerUid])
  @@index([userId])
}

// ---------------------------------------------------------------------------
// Hashed refresh tokens
// ---------------------------------------------------------------------------

model RefreshToken {
  id        String   @id @default(uuid(7))
  tokenHash String   @unique
  userAgent String?
  ip        String?
  expiresAt DateTime
  revokedAt DateTime?

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  createdAt DateTime @default(now())

  @@index([userId])
}

// ---------------------------------------------------------------------------
// User preferences (1-to-1)
// ---------------------------------------------------------------------------

model UserPreferences {
  id                     String  @id @default(uuid(7))
  defaultLanguage        String?
  notificationsEnabled   Boolean @default(true)

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String @unique
}

// ---------------------------------------------------------------------------
// Stub models referenced by User — filled out in later phases
// ---------------------------------------------------------------------------

model Evaluation {
  id     String @id @default(uuid(7))
  user   User   @relation(fields: [userId], references: [id])
  userId String

  createdAt DateTime @default(now())
}

model Preset {
  id     String @id @default(uuid(7))
  user   User?  @relation(fields: [userId], references: [id])
  userId String?
  name   String

  createdAt DateTime @default(now())
}

model DeveloperMemory {
  id               String   @id @default(uuid(7))
  acceptedRuleIds  String[]
  dismissedRuleIds String[]
  styleSignals     Json     @default("{}")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String @unique

  updatedAt DateTime @updatedAt
}

// ---------------------------------------------------------------------------
// Models for Githb PR review runs
// ---------------------------------------------------------------------------


enum WebhookDeliveryStatus {
  RECEIVED
  ENQUEUED
  PROCESSED
  IGNORED
  FAILED
}

enum PrReviewRunStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

model GitHubInstallation {
  installationId BigInt    @id
  accountLogin   String
  accountType    String
  suspendedAt    DateTime?
  installedAt    DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  webhookDeliveries WebhookDelivery[]

  @@index([accountLogin])
}

model WebhookDelivery {
  deliveryId     String                @id
  event          String
  action         String?
  installationId BigInt?
  installation   GitHubInstallation?   @relation(fields: [installationId], references: [installationId])
  repoFullName   String?
  prNumber       Int?
  headSha        String?
  baseSha        String?
  status         WebhookDeliveryStatus @default(RECEIVED)
  jobId          String?
  error          String?
  receivedAt     DateTime              @default(now())
  processedAt    DateTime?

  reviewRun PrReviewRun?

  @@index([status])
  @@index([repoFullName, prNumber])
}

model PrReviewRun {
  id              String            @id @default(uuid(7))
  deliveryId      String            @unique
  delivery        WebhookDelivery   @relation(fields: [deliveryId], references: [deliveryId])
  installationId  BigInt
  repoFullName    String
  prNumber        Int
  headSha         String
  baseSha         String
  status          PrReviewRunStatus @default(PENDING)
  summaryText     String?
  githubReviewId  BigInt?
  bullmqJobId     String?
  error           String?
  createdAt       DateTime          @default(now())
  completedAt     DateTime?

  @@index([repoFullName, prNumber])
  @@index([repoFullName, prNumber, headSha])
}